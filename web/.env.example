# Supabase Auth (leave empty to disable auth)
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# When VITE_SUPABASE_URL is unset, this user ID is used for all requests
VITE_AUTH_USER_ID=local-dev-user

# Account management URL
# VITE_ACCOUNT_URL=/account

# API base URL (used for REST and WebSocket connections)
# VITE_API_BASE_URL=http://localhost:8000
